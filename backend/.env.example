# Environment Configuration for LinguaFolio Backend
# Copy this file to .env.local and fill in your actual values

# ===== NODE ENVIRONMENT =====
NODE_ENV=production

# ===== SERVER =====
PORT=5005

# ===== SUPABASE (Required) =====
# Get these from Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== RAZORPAY (Required for Payments) =====
# Get these from Razorpay Dashboard > Settings > API Keys
# Use rzp_live_* for production, rzp_test_* for development
RAZORPAY_KEY_ID=rzp_live_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ===== CLIENT URLS FOR CORS =====
# Comma-separated list of allowed origins
CLIENT_URLS=https://yourdomain.com,https://www.yourdomain.com

# ===== DEBUG MODE =====
# Set to 'true' only in development to see detailed logs
DEBUG_LOGGING=false
